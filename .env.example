# Database - PostgreSQL 17 (C:\Program Files\PostgreSQL\17)
DATABASE_URL=postgresql://postgres:135353@localhost:5432/virtual_clinic

# Auth
JWT_SECRET=iran-virtual-clinic-secret-key-change-in-production
JWT_EXPIRE=24h
OTP_EXPIRE_MINUTES=10

# Mock SMS Provider
MOCK_SMS_ENABLED=true
MOCK_SMS_LOG_FILE=./logs/sms.log

# Server
NODE_ENV=development
NEXT_PUBLIC_APP_NAME=Iran Virtual Clinic
NEXT_PUBLIC_APP_URL=http://localhost:3000
